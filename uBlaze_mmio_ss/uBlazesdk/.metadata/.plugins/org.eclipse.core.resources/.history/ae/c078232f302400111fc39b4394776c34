void timer_check(GpoCore *led_p) {
    int i;

    for (i=0; i<5; i++) {
        led_p->write(0x003f);
        sleep_ms(500);
        led_p->write(0x0000);
        sleep_ms(500);
        debug("timer check - (loop #)/now: ", i, now_ms());
    }
}

void led_check(GpoCore *led_p, int n) {
    int i;

    for (i=0; i<n; i++) {
        led_p->write(1, i);
        sleep_ms(2000);
        led_p->write(0, i);
        sleep_ms(2000);
        debug("led check - (loop #)/now: ", i, now_ms());
    }
}

void sw_check(GpoCore *led_p, GpiCore *sw_p) {
    int i, s;

    s = sw_p->read();
    for (i=0; i<50; i++) {
        led_p->write(s);
        sleep_ms(200);
        led_p->write(0);
        sleep_ms(200);
        debug("sw check - (loop #)/now: ", i, now_ms());
    }
}

